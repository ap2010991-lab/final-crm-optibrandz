# Supabase Postgres
# Use the pooled connection string for the running app/API.
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Use the direct connection string for Prisma schema pushes/migrations.
DIRECT_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRES_IN=7d
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=grow@optibrandz.in
SMTP_PASS=your-app-password
CLOUDINARY_CLOUD_NAME=optibrandz
CLOUDINARY_API_KEY=your-key
CLOUDINARY_API_SECRET=your-secret
WA_PHONE_NUMBER_ID=your-phone-id
WA_ACCESS_TOKEN=your-access-token
PORT=3001
CLIENT_URL=http://localhost:5173
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
NODE_ENV=development
